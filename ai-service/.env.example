# FinGenie AI Service - Environment Configuration

# Service
SERVICE_NAME=fingenie-ai-service
ENVIRONMENT=development
DEBUG=true

# API
API_HOST=0.0.0.0
API_PORT=8000

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_CONSUMER_GROUP=fingenie-ai-consumers

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=fingenie-spending-predictor

# Model
AI_MODEL_VERSION=v1.0.0
AI_MODEL_PATH=/app/models
AI_FALLBACK_ENABLED=true
AI_INFERENCE_TIMEOUT_MS=300
BACKEND_URL=http://host.docker.internal:8080

# Logging
LOG_LEVEL=INFO
METRICS_ENABLED=true

# Vector Store (pgvector)
VECTOR_ENABLED=true
VECTOR_DB_URL=postgresql://fingenie:finpassword@postgres:5432/fingenie
VECTOR_TABLE=ai_embeddings
VECTOR_DIMENSION=384
VECTOR_TOP_K=5
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# LLM for RAG Chat
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1:8b-instruct-q4_0

# Gemini
GEMINI_API_KEY=your_real_key_here
GEMINI_MODEL=gemini-2.5-flash

# LLM Timeouts and Failure Cooldown
LLM_TIMEOUT_SECONDS=120
LLM_FAILURE_COOLDOWN_SECONDS=300
